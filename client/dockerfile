# ---- Stage 1: Builder ----
FROM node:20-slim AS builder

WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .

# next.config.js MUST have: output: 'standalone'
# Without this the runner stage below won't work.
RUN npm run build

# ---- Stage 2: Runner ----
# The standalone build bundles only what's needed — much smaller final image.
FROM node:20-slim AS runner

WORKDIR /app
ENV NODE_ENV=production

# Copy only the standalone output, static files, and public assets
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

EXPOSE 3000

CMD ["node", "server.js"]