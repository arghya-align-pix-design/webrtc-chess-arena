# ---- Base: Node 20 on Debian slim ----
# MediaSoup compiles native C++ (libwebrtc stuff) so it needs build tools.
# Alpine looks tempting but has known issues with mediasoup gyp builds — use slim.
FROM node:20-slim AS base

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    make \
    g++ \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# ---- Install deps first (layer-cached until package.json changes) ----
COPY package*.json ./
RUN npm ci

# ---- Copy source ----
COPY . .

# ---- Ports ----
# 8080 = HTTP/WebSocket
# 40000-50999 = MediaSoup RTP/RTCP (UDP + TCP)
EXPOSE 8080
EXPOSE 40000-50999/udp
EXPOSE 40000-50999/tcp

CMD ["node", "dist/index.js"]